# ── Runtime state ─────────────────────────────────────────────────────────
kriya.db
kriya.db-wal
kriya.db-shm
kriya.pid
kriya.sock
agentd.db
agentd.db-wal
agentd.db-shm
agentd.pid
agentd.sock

# ── Secrets & vault ────────────────────────────────────────────────────────
vault/*.enc
vault/master.key
vault/.vault_passphrase
/vault/
.jwt_secret
first_run_credentials.txt

# ── Logs ──────────────────────────────────────────────────────────────────
logs/*.jsonl
logs/*.log
/logs/

# ── Projects runtime data ─────────────────────────────────────────────────
projects/*/
/projects/

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Environment ───────────────────────────────────────────────────────────
.env
agentd.env
*.env.local

# ── User token (saved by CLI) ─────────────────────────────────────────────
.kriya_token
.agentd_token

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
